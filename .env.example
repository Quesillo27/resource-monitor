POSTGRES_DB=resource_monitor
POSTGRES_USER=monitor
POSTGRES_PASSWORD=change-this-db-password
JWT_SECRET=change-this-to-a-random-64-char-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
SERVER_ADDR=:8080
RETENTION_DAYS=30
OFFLINE_AFTER_SECONDS=180
VITE_API_BASE_URL=http://localhost:8080
# Comma-separated allowed CORS origins. Leave empty to allow all (dev only).
ALLOWED_ORIGINS=http://localhost:3000

# Versionado independiente: el manager (backend+frontend+infra) y el agente
# (binario que se distribuye a los equipos) tienen ciclos de release separados.
#
# AGENT_RELEASE_VERSION: prefix SemVer del agente. agent-assets compila
#   "<prefix>-<sha-del-último-commit-que-tocó-agent/>" y publica en
#   /downloads/version.txt. Solo bumpear cuando cambies código en agent/.
#
# MANAGER_VERSION: prefix SemVer del manager. El backend lo reporta en
#   /api/manager/version (junto al SHA del HEAD). Solo bumpear cuando cambies
#   código en backend/, frontend/, scripts/ o docker-compose.
#
# Bumpear con: ./scripts/set-version.sh manager v1.5.1   (o "agent v1.4.1")
AGENT_RELEASE_VERSION=v1.4.0
MANAGER_VERSION=v1.5.0
